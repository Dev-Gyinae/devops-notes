# ==============================================
# ADHIVE DOOH - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# SERVER CONFIGURATION
# ==============================================
NODE_ENV=development
PORT=3001

# ==============================================
# DATABASE (PostgreSQL)
# ==============================================
# Local development example:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/adhive_dooh

# Railway/Render hosted example:
# DATABASE_URL=postgresql://user:password@host.railway.app:5432/railway
DATABASE_URL=

# ==============================================
# JWT AUTHENTICATION
# ==============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ==============================================
# FRONTEND URLS (for CORS)
# ==============================================
CONTROL_WEB_URL=http://localhost:5173
DISPLAY_WEB_URL=http://localhost:5174

# In production:
# CONTROL_WEB_URL=https://control.adhive.com
# DISPLAY_WEB_URL=https://display.adhive.com

# ==============================================
# PAIRING CONFIGURATION
# ==============================================
PAIRING_CODE_LENGTH=6
PAIRING_CODE_EXPIRY_MINUTES=5

# ==============================================
# SOCKET.IO
# ==============================================
SOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ==============================================
# OPTIONAL: LOGGING & MONITORING
# ==============================================
LOG_LEVEL=debug
# SENTRY_DSN=
# NEW_RELIC_LICENSE_KEY=
