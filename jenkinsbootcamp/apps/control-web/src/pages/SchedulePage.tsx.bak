import { useState, useEffect } from 'react';
import { api } from '../lib/api';
import { useToast } from '../components/Toast';
import type { Campaign, Playlist, Screen } from '../types';

const CLUSTERS = [
  { id: 'RETAIL',        icon: '🛒', label: 'Retail' },
  { id: 'ENTERTAINMENT', icon: '🎭', label: 'Entertainment' },
  { id: 'CORPORATE',     icon: '🏢', label: 'Corporate' },
  { id: 'PUBLIC',        icon: '🏛',  label: 'Public' },
  { id: 'HEALTHCARE',    icon: '🏥', label: 'Healthcare' },
  { id: 'EDUCATION',     icon: '🎓', label: 'Education' },
];

const STATUS_STYLE: Record<string, { color: string; bg: string }> = {
  SCHEDULED: { color: '#fbbf24', bg: 'rgba(251,191,36,0.12)' },
  ACTIVE:    { color: '#34d399', bg: 'rgba(52,211,153,0.12)' },
  PAUSED:    { color: '#8b91b0', bg: 'rgba(139,145,176,0.12)' },
  COMPLETED: { color: '#7c8fff', bg: 'rgba(124,143,255,0.12)' },
  CANCELLED: { color: '#f87171', bg: 'rgba(248,113,113,0.12)' },
};

export function SchedulePage() {
  const { showToast } = useToast();
  const [campaigns, setCampaigns]   = useState<Campaign[]>([]);
  const [playlists, setPlaylists]   = useState<Playlist[]>([]);
  const [screens, setScreens]       = useState<Screen[]>([]);
  const [loading, setLoading]       = useState(true);
  const [showModal, setShowModal]   = useState(false);
  const [saving, setSaving]         = useState(false);

  // Form state
  const [name, setName]             = useState('');
  const [description, setDescription] = useState('');
  const [playlistId, setPlaylistId] = useState('');
  const [startDate, setStartDate]   = useState('');
  const [startTime, setStartTime]   = useState('08:00');
  const [endDate, setEndDate]       = useState('');
  const [endTime, setEndTime]       = useState('22:00');
  const [targetClusters, setTargetClusters]     = useState<string[]>([]);
  const [targetScreenIds, setTargetScreenIds]   = useState<string[]>([]);
  const [targetMode, setTargetMode] = useState<'cluster' | 'screens'>('cluster');

  useEffect(() => { loadData(); }, []);

  const loadData = async () => {
    try {
      const [c, p, s] = await Promise.all([
        api.getCampaigns().catch(() => []),
        api.getPlaylists(),
        api.getScreens().catch(() => []),
      ]);
      setCampaigns(c);
      setPlaylists(p);
      setScreens(s);
    } catch { showToast('Failed to load schedule data', 'error'); }
    finally { setLoading(false); }
  };

  const resetForm = () => {
    setName(''); setDescription(''); setPlaylistId('');
    setStartDate(''); setStartTime('08:00');
    setEndDate(''); setEndTime('22:00');
    setTargetClusters([]); setTargetScreenIds([]);
    setTargetMode('cluster');
  };

  const toggleCluster = (id: string) =>
    setTargetClusters(prev => prev.includes(id) ? prev.filter(c => c !== id) : [...prev, id]);

  const toggleScreen = (id: string) =>
    setTargetScreenIds(prev => prev.includes(id) ? prev.filter(s => s !== id) : [...prev, id]);

  const handleCreate = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!startDate || !endDate) { showToast('Fill in both start and end dates', 'error'); return; }
    const startISO = new Date(`${startDate}T${startTime}:00`).toISOString();
    const endISO   = new Date(`${endDate}T${endTime}:00`).toISOString();
    if (new Date(startISO) >= new Date(endISO)) { showToast('End must be after start', 'error'); return; }

    const clusters = targetMode === 'cluster' ? targetClusters : [];
    const screenIds = targetMode === 'screens' ? targetScreenIds : [];

    setSaving(true);
    try {
      await api.createCampaign({
        name, description, startDate: startISO, endDate: endISO, playlistId,
        targetClusters: clusters, targetScreenIds: screenIds,
      });
      setShowModal(false); resetForm();
      showToast(`Campaign "${name}" scheduled!`, 'success');
      loadData();
    } catch (err: any) {
      showToast(`Failed: ${err?.message || 'Check server logs'}`, 'error');
    } finally { setSaving(false); }
  };

  const handleDelete = async (id: string, cname: string) => {
    if (!confirm(`Cancel campaign "${cname}"?`)) return;
    try { await api.deleteCampaign(id); showToast('Campaign cancelled', 'info'); loadData(); }
    catch (err: any) { showToast(`Failed: ${err?.message || 'error'}`, 'error'); }
  };

  const handleToggle = async (campaign: Campaign) => {
    const next = campaign.status === 'PAUSED' ? 'ACTIVE' : 'PAUSED';
    try { await api.updateCampaign(campaign.id, { status: next }); loadData(); }
    catch (err: any) { showToast(`Failed: ${err?.message || 'error'}`, 'error'); }
  };

  const fmtDate = (d: string) => {
    try { return new Date(d).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }); }
    catch { return d; }
  };

  const daysRemaining = (endD: string) => {
    const diff = new Date(endD).getTime() - Date.now();
    const days = Math.ceil(diff / 86400000);
    if (days < 0)  return { label: 'Ended',       color: '#4a5070' };
    if (days === 0) return { label: 'Ends today',  color: '#fbbf24' };
    if (days <= 7)  return { label: `${days}d left`, color: '#fbbf24' };
    return             { label: `${days}d left`, color: '#34d399' };
  };

  const describeTargets = (campaign: Campaign) => {
    const parts: string[] = [];
    if (campaign.targetClusters?.length > 0)
      parts.push(campaign.targetClusters.map(c => CLUSTERS.find(cl => cl.id === c)?.label || c).join(', '));
    if (campaign.targetScreenIds?.length > 0) {
      const names = campaign.targetScreenIds
        .map(id => screens.find(s => s.id === id)?.name || id.slice(0, 6))
        .join(', ');
      parts.push(names);
    }
    return parts.length > 0 ? parts.join(' · ') : '— All screens';
  };

  const today = new Date().toISOString().split('T')[0];
  const scheduled = campaigns.filter(c => c.status === 'SCHEDULED').length;
  const active    = campaigns.filter(c => c.status === 'ACTIVE').length;
  const completed = campaigns.filter(c => c.status === 'COMPLETED').length;
  const paused    = campaigns.filter(c => c.status === 'PAUSED').length;
  const totalImpressions = campaigns.reduce((sum, c) => sum + (c.impressions || 0), 0);

  const baseInput: React.CSSProperties = {
    background: '#1a1e2b', border: '1px solid #242838', color: '#e2e4ed',
    borderRadius: '8px', padding: '10px 14px', fontSize: '14px',
    width: '100%', boxSizing: 'border-box', fontFamily: 'Inter, sans-serif',
  };

  if (loading) return (
    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '400px', color: '#8b91b0' }}>
      <div style={{ width: '24px', height: '24px', border: '2px solid #242838', borderTop: '2px solid #7c8fff', borderRadius: '50%', animation: 'spin 0.8s linear infinite', marginRight: '12px' }} />
      Loading schedule...
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  return (
    <div style={{ maxWidth: '1200px' }}>
      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        .camp-row:hover { background: #1a1e2b !important; }
        .camp-row { transition: background 0.15s; }
        .sched-input { background: #1a1e2b; border: 1px solid #242838; color: #e2e4ed; border-radius: 8px; padding: 10px 12px; font-size: 14px; width: 100%; box-sizing: border-box; font-family: Inter, sans-serif; }
        .sched-input:focus { outline: none; border-color: #7c8fff !important; }
        input[type="date"]::-webkit-calendar-picker-indicator,
        input[type="time"]::-webkit-calendar-picker-indicator { filter: invert(0.6); cursor: pointer; }
        input[type="date"], input[type="time"] { color-scheme: dark; }
        .target-btn { transition: all 0.15s; cursor: pointer; }
        .target-btn:hover { border-color: #7c8fff !important; }
        .screen-check:hover { background: #1a1e2b !important; }
        .screen-check { transition: background 0.15s; cursor: pointer; }
        .mode-tab { transition: all 0.15s; cursor: pointer; }
      `}</style>

      {/* Header */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '24px', flexWrap: 'wrap', gap: '12px' }}>
        <div>
          <h1 style={{ fontSize: '26px', fontWeight: '700', color: '#e2e4ed', letterSpacing: '-0.5px' }}>Schedule</h1>
          <p style={{ fontSize: '13px', color: '#8b91b0', marginTop: '4px' }}>
            Campaigns auto-activate at their start time and restore screens when they end
          </p>
        </div>
        <button onClick={() => setShowModal(true)}
          style={{ padding: '10px 18px', background: 'linear-gradient(135deg, #7c8fff 0%, #a78bfa 100%)', border: 'none', borderRadius: '8px', color: '#fff', fontSize: '14px', fontWeight: '600', cursor: 'pointer' }}>
          + New Campaign
        </button>
      </div>

      {/* Stats */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(6, 1fr)', gap: '12px', marginBottom: '24px' }}>
        {[
          { label: 'Total',       value: campaigns.length,  color: '#7c8fff' },
          { label: 'Active',      value: active,            color: '#34d399' },
          { label: 'Scheduled',   value: scheduled,         color: '#fbbf24' },
          { label: 'Paused',      value: paused,            color: '#8b91b0' },
          { label: 'Completed',   value: completed,         color: '#a78bfa' },
          { label: 'Impressions', value: totalImpressions,  color: '#fb923c' },
        ].map(s => (
          <div key={s.label} style={{ background: '#13161f', border: '1px solid #242838', borderRadius: '10px', padding: '16px 14px' }}>
            <div style={{ fontSize: '26px', fontWeight: '800', color: '#e2e4ed', letterSpacing: '-1px' }}>{s.value}</div>
            <div style={{ fontSize: '11px', color: s.color, fontWeight: '600', textTransform: 'uppercase', letterSpacing: '0.5px', marginTop: '2px' }}>{s.label}</div>
          </div>
        ))}
      </div>

      {/* Campaigns Table */}
      <div style={{ background: '#13161f', border: '1px solid #242838', borderRadius: '12px', overflow: 'hidden', marginBottom: '20px' }}>
        <div style={{ padding: '16px 20px', borderBottom: '1px solid #242838', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <h2 style={{ fontSize: '15px', fontWeight: '600', color: '#e2e4ed' }}>All Campaigns</h2>
          <span style={{ fontSize: '12px', color: '#4a5070' }}>{campaigns.length} total · scheduler checks every 60s</span>
        </div>

        {campaigns.length === 0 ? (
          <div style={{ textAlign: 'center', padding: '60px 40px' }}>
            <div style={{ fontSize: '40px', marginBottom: '12px' }}>📅</div>
            <div style={{ fontSize: '16px', fontWeight: '600', color: '#8b91b0', marginBottom: '6px' }}>No campaigns yet</div>
            <div style={{ fontSize: '13px', color: '#4a5070', marginBottom: '20px' }}>
              Create a campaign to target specific clusters or screens on a schedule
            </div>
            <button onClick={() => setShowModal(true)}
              style={{ padding: '10px 20px', background: 'linear-gradient(135deg, #7c8fff 0%, #a78bfa 100%)', border: 'none', borderRadius: '8px', color: '#fff', fontSize: '14px', fontWeight: '600', cursor: 'pointer' }}>
              + Create First Campaign
            </button>
          </div>
        ) : (
          <table style={{ width: '100%', borderCollapse: 'collapse' }}>
            <thead>
              <tr>
                {['Campaign', 'Playlist', 'Targets', 'Window', 'Remaining', 'Impressions', 'Status', 'Actions'].map(h => (
                  <th key={h} style={{ padding: '10px 16px', textAlign: 'left', fontSize: '11px', fontWeight: '600', color: '#4a5070', textTransform: 'uppercase', letterSpacing: '0.5px', borderBottom: '1px solid #242838', whiteSpace: 'nowrap' }}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {campaigns.map(c => {
                const pl  = playlists.find(p => p.id === c.playlistId);
                const rem = daysRemaining(c.endDate);
                const ss  = STATUS_STYLE[c.status] || { color: '#8b91b0', bg: 'rgba(74,80,112,0.3)' };
                return (
                  <tr key={c.id} className="camp-row" style={{ borderBottom: '1px solid #1a1e2b' }}>
                    <td style={{ padding: '14px 16px', maxWidth: '180px' }}>
                      <div style={{ fontSize: '14px', fontWeight: '600', color: '#e2e4ed' }}>{c.name}</div>
                      {c.description && <div style={{ fontSize: '11px', color: '#4a5070', marginTop: '2px' }}>{c.description}</div>}
                    </td>
                    <td style={{ padding: '14px 16px' }}>
                      {pl
                        ? <span style={{ fontSize: '12px', color: '#a78bfa', fontWeight: '500', background: 'rgba(167,139,250,0.1)', padding: '3px 8px', borderRadius: '5px' }}>{pl.name}</span>
                        : <span style={{ fontSize: '12px', color: '#4a5070' }}>—</span>}
                    </td>
                    <td style={{ padding: '14px 16px', maxWidth: '180px' }}>
                      <div style={{ fontSize: '11px', color: '#7c8fff' }}>{describeTargets(c)}</div>
                    </td>
                    <td style={{ padding: '14px 16px', fontSize: '12px', color: '#8b91b0', whiteSpace: 'nowrap' }}>
                      <div>{fmtDate(c.startDate)}</div>
                      <div style={{ color: '#4a5070' }}>→ {fmtDate(c.endDate)}</div>
                    </td>
                    <td style={{ padding: '14px 16px' }}>
                      <span style={{ fontSize: '11px', fontWeight: '600', color: rem.color }}>{rem.label}</span>
                    </td>
                    <td style={{ padding: '14px 16px' }}>
                      <div style={{ display: 'flex', alignItems: 'center', gap: '6px' }}>
                        <span style={{ fontSize: '14px', fontWeight: '700', color: '#fb923c' }}>{c.impressions || 0}</span>
                        <span style={{ fontSize: '10px', color: '#4a5070' }}>plays</span>
                      </div>
                    </td>
                    <td style={{ padding: '14px 16px' }}>
                      <span style={{ fontSize: '11px', fontWeight: '700', padding: '3px 10px', borderRadius: '20px', background: ss.bg, color: ss.color }}>{c.status}</span>
                    </td>
                    <td style={{ padding: '14px 16px' }}>
                      <div style={{ display: 'flex', gap: '6px' }}>
                        {(c.status === 'ACTIVE' || c.status === 'PAUSED') && (
                          <button onClick={() => handleToggle(c)}
                            style={{ padding: '5px 10px', background: 'transparent', border: '1px solid #242838', borderRadius: '6px', color: '#8b91b0', fontSize: '12px', cursor: 'pointer' }}>
                            {c.status === 'ACTIVE' ? '⏸' : '▶'}
                          </button>
                        )}
                        {c.status !== 'COMPLETED' && (
                          <button onClick={() => handleDelete(c.id, c.name)}
                            style={{ padding: '5px 10px', background: 'transparent', border: '1px solid rgba(248,113,113,0.3)', borderRadius: '6px', color: '#f87171', fontSize: '12px', cursor: 'pointer' }}>
                            Cancel
                          </button>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        )}
      </div>

      {/* Timeline */}
      {campaigns.length > 0 && (
        <div style={{ background: '#13161f', border: '1px solid #242838', borderRadius: '12px', padding: '20px' }}>
          <h2 style={{ fontSize: '15px', fontWeight: '600', color: '#e2e4ed', marginBottom: '16px' }}>Timeline</h2>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
            {[...campaigns].sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime()).map(c => {
              const ss = STATUS_STYLE[c.status] || { color: '#7c8fff', bg: 'rgba(124,143,255,0.1)' };
              const duration = Math.max(1, Math.ceil((new Date(c.endDate).getTime() - new Date(c.startDate).getTime()) / 86400000));
              const targets = describeTargets(c);
              return (
                <div key={c.id} style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
                  <div style={{ width: '90px', fontSize: '11px', color: '#8b91b0', flexShrink: 0, textAlign: 'right' }}>{fmtDate(c.startDate)}</div>
                  <div style={{ flex: 1, height: '34px', borderRadius: '6px', background: ss.bg, border: `1px solid ${ss.color}40`, display: 'flex', alignItems: 'center', padding: '0 10px', gap: '8px', overflow: 'hidden' }}>
                    <span style={{ fontSize: '12px', fontWeight: '600', color: ss.color, whiteSpace: 'nowrap' }}>{c.name} · {duration}d</span>
                    <span style={{ fontSize: '11px', color: ss.color, opacity: 0.6, whiteSpace: 'nowrap' }}>{targets}</span>
                    {c.impressions > 0 && <span style={{ marginLeft: 'auto', fontSize: '11px', color: '#fb923c', whiteSpace: 'nowrap', flexShrink: 0 }}>{c.impressions} plays</span>}
                  </div>
                  <div style={{ width: '90px', fontSize: '11px', color: '#8b91b0', flexShrink: 0 }}>{fmtDate(c.endDate)}</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* ─── CREATE MODAL ─── */}
      {showModal && (
        <div onClick={() => { setShowModal(false); resetForm(); }}
          style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.8)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 1000, padding: '20px' }}>
          <div onClick={e => e.stopPropagation()}
            style={{ background: '#13161f', border: '1px solid #242838', borderRadius: '16px', padding: '32px', width: '100%', maxWidth: '560px', maxHeight: '92vh', overflowY: 'auto' }}>

            <h2 style={{ fontSize: '20px', fontWeight: '700', color: '#e2e4ed', marginBottom: '4px' }}>New Campaign</h2>
            <p style={{ fontSize: '13px', color: '#8b91b0', marginBottom: '24px' }}>
              Schedule a playlist to auto-run on targeted screens between two dates
            </p>

            <form onSubmit={handleCreate}>

              {/* Name */}
              <div style={{ marginBottom: '14px' }}>
                <label style={{ display: 'block', fontSize: '12px', color: '#8b91b0', marginBottom: '6px', fontWeight: '500' }}>Campaign Name *</label>
                <input className="sched-input" type="text" value={name} onChange={e => setName(e.target.value)}
                  placeholder="e.g. Lunch Rush, Ramadan Promo, MTN Launch" required autoFocus />
              </div>

              {/* Description */}
              <div style={{ marginBottom: '14px' }}>
                <label style={{ display: 'block', fontSize: '12px', color: '#8b91b0', marginBottom: '6px', fontWeight: '500' }}>Description (optional)</label>
                <input className="sched-input" type="text" value={description} onChange={e => setDescription(e.target.value)}
                  placeholder="Client name, campaign brief..." />
              </div>

              {/* Playlist */}
              <div style={{ marginBottom: '20px' }}>
                <label style={{ display: 'block', fontSize: '12px', color: '#8b91b0', marginBottom: '6px', fontWeight: '500' }}>Playlist to Run *</label>
                <select value={playlistId} onChange={e => setPlaylistId(e.target.value)} required
                  style={{ ...baseInput, cursor: 'pointer' }} className="sched-input">
                  <option value="">Select a playlist...</option>
                  {playlists.map(p => <option key={p.id} value={p.id}>{p.name}{p.isActive ? '' : ' (inactive)'}</option>)}
                </select>
                {playlists.length === 0 && <p style={{ fontSize: '11px', color: '#fbbf24', marginTop: '5px' }}>⚠️ Create a playlist first in the Playlists section</p>}
              </div>

              {/* ── TARGETING ── */}
              <div style={{ background: '#0e1018', border: '1px solid #242838', borderRadius: '10px', padding: '16px', marginBottom: '20px' }}>
                <div style={{ fontSize: '12px', color: '#8b91b0', fontWeight: '600', marginBottom: '12px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  🎯 Target Screens
                </div>
                <p style={{ fontSize: '12px', color: '#4a5070', marginBottom: '14px' }}>
                  Choose which screens get this campaign. Leave both empty to target all screens.
                </p>

                {/* Mode toggle */}
                <div style={{ display: 'flex', gap: '8px', marginBottom: '14px' }}>
                  {[
                    { id: 'cluster', label: '📍 By Cluster' },
                    { id: 'screens', label: '🖥 Specific Screens' },
                  ].map(m => (
                    <button key={m.id} type="button" onClick={() => setTargetMode(m.id as any)} className="mode-tab"
                      style={{ padding: '7px 14px', borderRadius: '7px', border: '1px solid', fontSize: '12px', fontWeight: '500',
                        borderColor: targetMode === m.id ? '#7c8fff' : '#242838',
                        background: targetMode === m.id ? 'rgba(124,143,255,0.12)' : 'transparent',
                        color: targetMode === m.id ? '#7c8fff' : '#8b91b0' }}>
                      {m.label}
                    </button>
                  ))}
                </div>

                {/* Cluster picker */}
                {targetMode === 'cluster' && (
                  <div>
                    <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '8px' }}>
                      {CLUSTERS.map(c => {
                        const active = targetClusters.includes(c.id);
                        // Count screens in this cluster
                        const count = screens.filter(s => s.cluster === c.id).length;
                        return (
                          <button key={c.id} type="button" onClick={() => toggleCluster(c.id)} className="target-btn"
                            style={{ padding: '10px 8px', borderRadius: '8px', border: '1px solid',
                              borderColor: active ? '#7c8fff' : '#242838',
                              background: active ? 'rgba(124,143,255,0.12)' : 'transparent',
                              color: active ? '#7c8fff' : '#8b91b0',
                              fontSize: '12px', fontWeight: '500', textAlign: 'left' }}>
                            <div>{c.icon} {c.label}</div>
                            <div style={{ fontSize: '10px', marginTop: '3px', color: active ? '#7c8fff99' : '#4a5070' }}>
                              {count} screen{count !== 1 ? 's' : ''}
                            </div>
                            {active && <div style={{ float: 'right', marginTop: '-20px' }}>✓</div>}
                          </button>
                        );
                      })}
                    </div>
                    {targetClusters.length > 0 && (
                      <div style={{ marginTop: '10px', fontSize: '12px', color: '#7c8fff', padding: '6px 10px', background: 'rgba(124,143,255,0.06)', borderRadius: '6px' }}>
                        Targeting: {targetClusters.map(id => CLUSTERS.find(c => c.id === id)?.label).join(', ')} ·{' '}
                        {screens.filter(s => targetClusters.includes(s.cluster || '')).length} screens
                      </div>
                    )}
                    {targetClusters.length === 0 && (
                      <div style={{ marginTop: '10px', fontSize: '11px', color: '#4a5070' }}>
                        No cluster selected — will target all screens
                      </div>
                    )}
                  </div>
                )}

                {/* Specific screen picker */}
                {targetMode === 'screens' && (
                  <div>
                    {screens.length === 0 ? (
                      <div style={{ fontSize: '13px', color: '#4a5070', padding: '12px 0' }}>No screens paired yet</div>
                    ) : (
                      <div style={{ display: 'flex', flexDirection: 'column', gap: '6px', maxHeight: '200px', overflowY: 'auto' }}>
                        {screens.map(s => {
                          const checked = targetScreenIds.includes(s.id);
                          return (
                            <div key={s.id} onClick={() => toggleScreen(s.id)} className="screen-check"
                              style={{ display: 'flex', alignItems: 'center', gap: '10px', padding: '8px 10px', borderRadius: '7px',
                                border: '1px solid', borderColor: checked ? '#7c8fff' : '#242838',
                                background: checked ? 'rgba(124,143,255,0.06)' : 'transparent' }}>
                              <div style={{ width: '16px', height: '16px', borderRadius: '4px', border: '1px solid',
                                borderColor: checked ? '#7c8fff' : '#4a5070',
                                background: checked ? '#7c8fff' : 'transparent',
                                display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0 }}>
                                {checked && <span style={{ color: '#fff', fontSize: '10px', fontWeight: '700' }}>✓</span>}
                              </div>
                              <div style={{ flex: 1 }}>
                                <div style={{ fontSize: '13px', fontWeight: '500', color: '#e2e4ed' }}>{s.name}</div>
                                <div style={{ fontSize: '11px', color: '#4a5070' }}>
                                  {s.venueName ? `${s.venueName}${s.cluster ? ` · ${s.cluster}` : ''}` : s.cluster || 'No location set'}
                                </div>
                              </div>
                              <div style={{ width: '7px', height: '7px', borderRadius: '50%', flexShrink: 0,
                                background: s.status === 'ONLINE' ? '#34d399' : '#f87171' }} />
                            </div>
                          );
                        })}
                      </div>
                    )}
                    {targetScreenIds.length > 0 && (
                      <div style={{ marginTop: '10px', fontSize: '12px', color: '#7c8fff', padding: '6px 10px', background: 'rgba(124,143,255,0.06)', borderRadius: '6px' }}>
                        {targetScreenIds.length} screen{targetScreenIds.length !== 1 ? 's' : ''} selected
                      </div>
                    )}
                  </div>
                )}
              </div>

              {/* ── CAMPAIGN WINDOW ── */}
              <div style={{ background: '#0e1018', border: '1px solid #242838', borderRadius: '10px', padding: '16px', marginBottom: '22px' }}>
                <div style={{ fontSize: '12px', color: '#8b91b0', fontWeight: '600', marginBottom: '14px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📅 Campaign Window
                </div>
                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px' }}>
                  <div>
                    <div style={{ fontSize: '11px', color: '#7c8fff', fontWeight: '600', marginBottom: '8px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>▶ Start</div>
                    <div style={{ marginBottom: '8px' }}>
                      <label style={{ display: 'block', fontSize: '11px', color: '#4a5070', marginBottom: '4px' }}>Date *</label>
                      <input type="date" value={startDate}
                        onChange={e => { setStartDate(e.target.value); if (!endDate || e.target.value > endDate) setEndDate(e.target.value); }}
                        min={today} required className="sched-input" />
                    </div>
                    <div>
                      <label style={{ display: 'block', fontSize: '11px', color: '#4a5070', marginBottom: '4px' }}>Time</label>
                      <input type="time" value={startTime} onChange={e => setStartTime(e.target.value)} className="sched-input" />
                    </div>
                  </div>
                  <div>
                    <div style={{ fontSize: '11px', color: '#f87171', fontWeight: '600', marginBottom: '8px', textTransform: 'uppercase', letterSpacing: '0.5px' }}>⏹ End</div>
                    <div style={{ marginBottom: '8px' }}>
                      <label style={{ display: 'block', fontSize: '11px', color: '#4a5070', marginBottom: '4px' }}>Date *</label>
                      <input type="date" value={endDate} onChange={e => setEndDate(e.target.value)}
                        min={startDate || today} required className="sched-input" />
                    </div>
                    <div>
                      <label style={{ display: 'block', fontSize: '11px', color: '#4a5070', marginBottom: '4px' }}>Time</label>
                      <input type="time" value={endTime} onChange={e => setEndTime(e.target.value)} className="sched-input" />
                    </div>
                  </div>
                </div>
                {startDate && endDate && (() => {
                  const days = Math.ceil((new Date(`${endDate}T${endTime}`).getTime() - new Date(`${startDate}T${startTime}`).getTime()) / 86400000);
                  return (
                    <div style={{ marginTop: '12px', padding: '8px 12px', background: days > 0 ? 'rgba(124,143,255,0.08)' : 'rgba(248,113,113,0.08)', borderRadius: '6px', fontSize: '12px', color: days > 0 ? '#7c8fff' : '#f87171', textAlign: 'center' }}>
                      {days > 0 ? `Runs for ${days} day${days > 1 ? 's' : ''} · ${startDate} to ${endDate}` : '⚠ End must be after start'}
                    </div>
                  );
                })()}
              </div>

              <div style={{ display: 'flex', gap: '10px' }}>
                <button type="button" onClick={() => { setShowModal(false); resetForm(); }}
                  style={{ flex: 1, padding: '11px', background: 'transparent', border: '1px solid #242838', borderRadius: '8px', color: '#8b91b0', fontSize: '14px', cursor: 'pointer' }}>
                  Cancel
                </button>
                <button type="submit" disabled={saving || !name || !startDate || !endDate || !playlistId}
                  style={{ flex: 2, padding: '11px', background: (saving || !name || !startDate || !endDate || !playlistId) ? '#1a1e2b' : 'linear-gradient(135deg, #7c8fff 0%, #a78bfa 100%)', border: 'none', borderRadius: '8px', color: '#fff', fontSize: '14px', fontWeight: '600', cursor: saving ? 'not-allowed' : 'pointer' }}>
                  {saving ? 'Scheduling...' : 'Schedule Campaign'}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
}
