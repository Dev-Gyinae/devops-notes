pipeline {
    agent any

    parameters {
        booleanParam(name: 'FORCE_BUILD', defaultValue: false,
            description: 'Force build even if image already exists')
    }

    environment {
        APP_NAME = "adhive-api"

        // ✅ Correct Docker Hub registry
        DOCKERHUB_REGISTRY = "https://index.docker.io/v1/"
        DOCKERHUB_REPO = "gyinae/demo-app"
        DOCKERHUB_CREDS_ID = "dockerhub-creds"

        // Nexus
        NEXUS_REGISTRY = "192.168.122.166:8083"
        NEXUS_REPO = "docker-hosted"
        NEXUS_CREDS_ID = "Nexus-Repo-Bootcamp"
    }

    stages {

        stage('Checkout Source') {
            steps {
                checkout scm
            }
        }

        stage('Resolve Version (Git SHA)') {
            steps {
                script {
                    env.GIT_SHA = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()

                    env.IMAGE_TAG = "${APP_NAME}:${GIT_SHA}"

                    env.DOCKERHUB_TAG =
                        "${DOCKERHUB_REPO}:${APP_NAME}-${GIT_SHA}"

                    env.NEXUS_TAG =
                        "${NEXUS_REGISTRY}/${NEXUS_REPO}/${APP_NAME}:${GIT_SHA}"

                    echo "Version (commit): ${GIT_SHA}"
                }
            }
        }

        stage('Check If Image Exists') {
            steps {
                script {
                    def exists = false

                    try {
                        sh "docker manifest inspect ${NEXUS_TAG}"
                        exists = true
                        echo "✅ Image already exists in Nexus"
                    } catch (e) {
                        echo "🚧 Image not found — build required"
                    }

                    env.SKIP_BUILD =
                        (exists && !params.FORCE_BUILD).toString()

                    echo "Skip build: ${env.SKIP_BUILD}"
                }
            }
        }

        stage('Build Image') {
            when {
                expression { env.SKIP_BUILD != 'true' }
            }
            steps {
                script {
                    echo "🚧 Building image ${IMAGE_TAG}"

                    docker.build(IMAGE_TAG, "./server")

                    sh "docker tag ${IMAGE_TAG} ${APP_NAME}:latest"
                }
            }
        }

        stage('Push → Docker Hub') {
            when {
                expression { env.SKIP_BUILD != 'true' }
            }
            steps {
                script {
                    docker.withRegistry(
                        DOCKERHUB_REGISTRY,
                        DOCKERHUB_CREDS_ID
                    ) {
                        sh """
                        docker tag ${IMAGE_TAG} ${DOCKERHUB_TAG}
                        docker push ${DOCKERHUB_TAG}

                        docker tag ${APP_NAME}:latest ${DOCKERHUB_REPO}:${APP_NAME}-latest
                        docker push ${DOCKERHUB_REPO}:${APP_NAME}-latest
                        """
                    }
                }
            }
        }

        stage('Push → Nexus') {
            when {
                expression { env.SKIP_BUILD != 'true' }
            }
            steps {
                script {
                    docker.withRegistry(
                        "http://${NEXUS_REGISTRY}",
                        NEXUS_CREDS_ID
                    ) {
                        sh """
                        docker tag ${IMAGE_TAG} ${NEXUS_TAG}
                        docker push ${NEXUS_TAG}

                        docker tag ${APP_NAME}:latest ${NEXUS_REGISTRY}/${NEXUS_REPO}/${APP_NAME}:latest
                        docker push ${NEXUS_REGISTRY}/${NEXUS_REPO}/${APP_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Skip Message') {
            when {
                expression { env.SKIP_BUILD == 'true' }
            }
            steps {
                echo "⏭️ Image already exists for commit ${GIT_SHA}"
            }
        }
    }

    post {
        success {
            echo """
================================
✅ PIPELINE SUCCESS

Commit: ${GIT_SHA}
Image: ${APP_NAME}

DockerHub:
${DOCKERHUB_REPO}:${APP_NAME}-${GIT_SHA}

Nexus:
${NEXUS_TAG}
================================
"""
        }

        failure {
            echo "❌ Pipeline failed."
        }
    }
}